{
  "name": "rhess",
  "version": "0.1.0",
  "description": "Red Hat Enterprise Skills Server — self-hosted AI agent skills directory",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:ui": "vite",
    "build": "npm run build:ui && npm run build:server",
    "build:ui": "vite build",
    "build:server": "tsc --project tsconfig.server.json",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^8.1.0",
    "better-sqlite3": "^11.10.0",
    "fastify": "^5.3.3",
    "fuse.js": "^7.1.0",
    "js-yaml": "^4.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-git": "^3.27.0",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.29",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/tar": "^6.1.13",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.28.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^6.3.5",
    "vitest": "^3.2.3"
  }
}
